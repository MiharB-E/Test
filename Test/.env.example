# InvCasa – required environment variables
# Copy this file to backend/.env and fill in your values.
# Run: cp .env.example backend/.env

# ─── Security (REQUIRED – app won't start without these) ──────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=change-this-to-a-64-char-random-hex-string
REFRESH_TOKEN_SECRET_KEY=change-this-to-another-64-char-random-hex-string

# ─── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
SECURE_COOKIES=false        # set to true in production (HTTPS)
FRONTEND_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:////app/data/invcasa.db
# For PostgreSQL: DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/invcasa

# ─── Email / SMTP (optional – leave blank to disable email sending) ────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=InvCasa

# ─── Demo data ────────────────────────────────────────────────────────────────
# Set to true ONLY in local dev/testing to seed a demo user on cold start
SEED_DEMO_DATA=false
